
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a student, teacher, or admin.",
      "type": "object",
      "properties": {
        "usn_emp": { "type": "string", "description": "The unique ID number (USN for students, EMP for staff)." },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "teacher", "student", "library_admin"] },
        "program": { "type": "string", "description": "Academic program (e.g., BSCS)." },
        "year": { "type": "string", "description": "Current year level." },
        "profilePic": { "type": "string", "description": "Data URI or path for profile picture." }
      },
      "required": ["usn_emp", "name", "email", "role"]
    },
    "Subject": {
      "title": "Subject",
      "description": "A class subject added by a teacher.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "time": { "type": "string", "description": "Start time (e.g., 08:00 AM)." },
        "day": { "type": "string", "description": "Days of week (e.g., Mon/Wed)." }
      },
      "required": ["title", "teacherId", "time", "day"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "Link between a student and a subject.",
      "type": "object",
      "properties": {
        "subjectId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "program": { "type": "string" },
        "year": { "type": "string" }
      },
      "required": ["subjectId", "studentId"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Attendance record marked via QR scan.",
      "type": "object",
      "properties": {
        "subjectId": { "type": "string" },
        "studentId": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] }
      },
      "required": ["subjectId", "studentId", "date", "status"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "A reservation for a room or lab made by a teacher.",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "subjectId": { "type": "string" },
        "locationId": { "type": "string" },
        "locationType": { "type": "string", "enum": ["room", "lab"] },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string", "format": "time" },
        "endTime": { "type": "string", "format": "time" }
      },
      "required": ["teacherId", "subjectId", "locationId", "locationType", "date", "startTime", "endTime"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles stored by UID."
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Collection of all school subjects."
    },
    "/subjects/{subjectId}/enrollments/{enrollId}": {
      "schema": "Enrollment",
      "description": "Students enrolled in a specific subject."
    },
    "/attendance/{recordId}": {
      "schema": "Attendance",
      "description": "Attendance logs."
    },
    "/reservations/{reservationId}": {
      "schema": "Reservation",
      "description": "Room and lab reservations."
    }
  }
}
