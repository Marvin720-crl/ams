
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a student, teacher, or admin.",
      "type": "object",
      "properties": {
        "usn_emp": { "type": "string", "description": "The unique ID number (USN for students, EMP for staff)." },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "teacher", "student", "library_admin"] },
        "department": { "type": "string", "enum": ["college", "shs"] },
        "program": { "type": "string", "description": "Academic program (e.g., BSCS or STEM)." },
        "year": { "type": "string", "description": "Current year level." },
        "profilePic": { "type": "string", "description": "Data URI or path for profile picture." },
        "emergencyContactName": { "type": "string", "description": "Name of the person to contact in an emergency." },
        "emergencyContactAddress": { "type": "string", "description": "Address of the emergency contact." },
        "emergencyContactPhone": { "type": "string", "description": "Phone number of the emergency contact." },
        "lastSeen": { "type": "string", "format": "date-time", "description": "Last activity timestamp for online status." }
      },
      "required": ["usn_emp", "name", "email", "role"]
    },
    "Subject": {
      "title": "Subject",
      "description": "A class subject added by a teacher.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "time": { "type": "string", "description": "Start time (e.g., 08:00 AM)." },
        "day": { "type": "string", "description": "Days of week (e.g., Mon/Wed)." },
        "department": { "type": "string", "enum": ["college", "shs"] }
      },
      "required": ["title", "teacherId", "time", "day"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat room for subjects or private messages.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["subject", "private", "general"] },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "teacherId": { "type": "string" },
        "subjectId": { "type": "string" }
      },
      "required": ["id", "type", "memberIds"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message sent within a conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "call_log"] }
      },
      "required": ["id", "conversationId", "senderId", "text", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles stored by UID."
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Collection of all school subjects."
    },
    "/conversations/{convId}": {
      "schema": "Conversation",
      "description": "Chat rooms."
    },
    "/conversations/{convId}/messages/{msgId}": {
      "schema": "ChatMessage",
      "description": "Messages within a conversation."
    }
  }
}
